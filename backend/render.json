{
  "startCommand": "npm start",
  "buildCommand": "npm install && npm run build",
  "envVars": [
    {
      "key": "NODE_ENV",
      "value": "production"
    },
    {
      "key": "OPENAI_API_KEY"
    },
    {
      "key": "SUPABASE_URL"
    },
    {
      "key": "SUPABASE_ANON_KEY"
    },
    {
      "key": "SUPABASE_SERVICE_ROLE_KEY"
    },
    {
      "key": "CORS_ORIGIN"
    },
    {
      "key": "CORS_ORIGIN_PROD"
    }
  ]
}
