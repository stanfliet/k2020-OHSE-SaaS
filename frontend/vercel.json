{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "env": [
    {
      "key": "VITE_SUPABASE_URL",
      "value": "@supabase_url"
    },
    {
      "key": "VITE_SUPABASE_ANON_KEY",
      "value": "@supabase_anon_key"
    },
    {
      "key": "VITE_API_URL",
      "value": "@api_url"
    }
  ]
}
