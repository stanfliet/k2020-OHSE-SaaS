{
  "name": "k2020-ohse-saas",
  "version": "1.0.0",
  "description": "AI-powered Occupational Health, Safety, Environment, and Construction Compliance SaaS",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "npm --prefix backend run dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "build": "npm --prefix frontend run build && npm --prefix backend run build",
    "build:frontend": "npm --prefix frontend run build",
    "build:backend": "npm --prefix backend run build",
    "start": "npm --prefix backend start",
    "start:backend": "npm --prefix backend start",
    "start:frontend": "npm --prefix frontend start"
  }
}
